{
  auto_https off
}

(qr_routes) {
  # ACME challenge must hit Traefik LB (MetalLB IP)
  handle /.well-known/acme-challenge/* {
    reverse_proxy 192.168.1.220:80 {
      header_up Host {host}
    }
  }

  # API via NodePort on the host (reachable from container via host-gateway)
  handle /api* {
    reverse_proxy host.docker.internal:30080 {
      header_up Host {host}
    }
  }

  # everything else (frontend/static) via NodePort too
  handle {
    reverse_proxy host.docker.internal:30080 {
      header_up Host {host}
    }
  }
}

# HTTP — used by CI smoke test (localhost:80) and ACME challenges
http://qr.blainweb.com {
  import qr_routes
}

# HTTPS — Cloudflare origin (Full SSL mode) connects here
qr.blainweb.com {
  tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
  import qr_routes
}

# CV site — HTTP only at origin
http://cv.blainweb.com {
  root * /srv/cv
  file_server
}

# Grafana via Docker
http://grafana.blainweb.com {
  reverse_proxy grafana:3000
}

# Argo CD UI — HTTP (for internal/CI access)
http://argocd.blainweb.com {
  handle /.well-known/acme-challenge/* {
    reverse_proxy 192.168.1.220:80 {
      header_up Host {host}
    }
  }

  handle {
    reverse_proxy 192.168.1.220:80 {
      header_up Host {host}
      flush_interval -1
    }
  }
}

# Argo CD UI — HTTPS (Cloudflare origin connects here)
argocd.blainweb.com {
  tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

  handle /.well-known/acme-challenge/* {
    reverse_proxy 192.168.1.220:80 {
      header_up Host {host}
    }
  }

  handle {
    reverse_proxy 192.168.1.220:80 {
      header_up Host {host}
      flush_interval -1
    }
  }
}