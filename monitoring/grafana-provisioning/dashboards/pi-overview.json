{
  "id": null,
  "uid": "pi-overview",
  "title": "Pi & Containers Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["pi", "containers", "ops"],
  "panels": [
    {
      "type": "gauge",
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "targets": [
        { "expr": "100 - avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100", "legendFormat": "CPU" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "gauge",
      "title": "Memory Used %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "Mem" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "gauge",
      "title": "Root Disk Used %",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100",
          "legendFormat": "Disk"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "type": "timeseries",
      "title": "Network RX/TX (bytes/sec)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo\"}[5m])", "legendFormat": "{{device}} rx" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo\"}[5m])", "legendFormat": "{{device}} tx" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "type": "bargauge",
      "title": "Top 5 Containers by CPU %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } },
      "options": { "displayMode": "basic" },
      "targets": [
        { "expr": "topk(5, 100 * sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) by (name))", "legendFormat": "{{name}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "bargauge",
      "title": "Top 5 Containers by Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } },
      "options": { "displayMode": "basic" },
      "targets": [
        { "expr": "topk(5, sum(container_memory_working_set_bytes{image!=\"\"}) by (name))", "legendFormat": "{{name}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "type": "stat",
      "title": "Targets Up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "sum(up)", "legendFormat": "up" } ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Uptime (seconds)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "time() - node_boot_time_seconds", "legendFormat": "uptime" } ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Prometheus Samples/s",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "rate(prometheus_tsdb_head_samples_appended_total[5m])", "legendFormat": "samples/s" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "type": "timeseries",
      "title": "System Load (1/5/15m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "node_load1", "legendFormat": "load1" },
        { "expr": "node_load5", "legendFormat": "load5" },
        { "expr": "node_load15", "legendFormat": "load15" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "gauge",
      "title": "CPU Temperature (°C)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "celsius", "min": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "targets": [
        { "expr": "max(node_hwmon_temp_celsius) or max(node_thermal_zone_temp)", "legendFormat": "temp" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Disk I/O (bytes/sec)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (device) (rate(node_disk_read_bytes_total{device=~\"sd.*|mmcblk.*\"}[5m]))", "legendFormat": "{{device}} read" },
        { "expr": "sum by (device) (rate(node_disk_written_bytes_total{device=~\"sd.*|mmcblk.*\"}[5m]))", "legendFormat": "{{device}} write" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "type": "bargauge",
      "title": "Top 5 Containers by FS Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } },
      "options": { "displayMode": "basic" },
      "targets": [
        { "expr": "topk(5, sum(container_fs_usage_bytes{image!=\"\"}) by (name))", "legendFormat": "{{name}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Network Errors (rx/tx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "rate(node_network_receive_errs_total{device!=\"lo\"}[5m])", "legendFormat": "{{device}} rx_err" },
        { "expr": "rate(node_network_transmit_errs_total{device!=\"lo\"}[5m])", "legendFormat": "{{device}} tx_err" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Container Memory (MB) – namespace=qr",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "megabytes", "min": 0 } },
      "options": { "legend": { "showLegend": true, "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "(sum by (pod, name) (container_memory_working_set_bytes{namespace=\"qr\", image!=\"\"})) / 1024 / 1024",
          "legendFormat": "{{pod}}/{{name}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "bargauge",
      "title": "Top Memory Growers (Δ working_set over time range) – namespace=qr",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
      "fieldConfig": { "defaults": { "unit": "megabytes", "min": 0 } },
      "options": { "displayMode": "gradient" },
      "targets": [
        {
          "expr": "topk(8, ( max_over_time((sum by (pod, name) (container_memory_working_set_bytes{namespace=\"qr\", image!=\"\"}))[$__range:1m]) - min_over_time((sum by (pod, name) (container_memory_working_set_bytes{namespace=\"qr\", image!=\"\"}))[$__range:1m]) ) / 1024 / 1024 )",
          "legendFormat": "{{pod}}/{{name}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "table",
      "title": "Container Restarts (in range) – namespace=qr",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "showHeader": true },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Value": false } } }
      ],
      "targets": [
        {
          "expr": "sum by (pod, container) (increase(kube_pod_container_status_restarts_total{namespace=\"qr\"}[$__range]))",
          "legendFormat": "{{pod}}/{{container}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "stat",
      "title": "Velero backup attempts (in range)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 64 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "increase(velero_backup_attempt_total[$__range])", "legendFormat": "attempts" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "query": { "query": "label_values(container_memory_working_set_bytes{image!=\"\"}, name)", "refId": "VarQuery" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 2,
        "hide": 0,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [ { "builtIn": 1, "type": "dashboard", "name": "Annotations & Alerts", "hide": true } ] }
}